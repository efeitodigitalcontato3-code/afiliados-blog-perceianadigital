---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../siteConfig.json';

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection('blog');
  const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
  return paginate(sortedPosts, { pageSize: 15 });
}

const { page } = Astro.props;

// Identificar se é a primeira página
const isFirstPage = page.currentPage === 1;

// Get all posts for dynamic category listings on the first page
const allPosts = await getCollection('blog');
const sortedAllPosts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Featured post (the very latest)
const heroPost = sortedAllPosts[0] || null;

// Recent posts (excluding hero)
const recentPosts = sortedAllPosts.slice(1, 7);

// Dynamic categories extraction
const categoriesList = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];

// Fallback categories if empty
const displayCategories = categoriesList.length > 0 ? categoriesList : ["Geral", "Análises", "Dicas", "Guias"];

// Category colors for the beautiful category badge cards
const categoryColors = [
  { bg: "linear-gradient(135deg, #e0f2fe, #bae6fd)", text: "#0369a1", border: "#7dd3fc", icon: "🌐" }, // Blue
  { bg: "linear-gradient(135deg, #fef3c7, #fde68a)", text: "#b45309", border: "#fcd34d", icon: "⭐" }, // Yellow/Gold
  { bg: "linear-gradient(135deg, #dcfce7, #bbf7d0)", text: "#15803d", border: "#86efac", icon: "🌿" }, // Green
  { bg: "linear-gradient(135deg, #ffedd5, #fed7aa)", text: "#c2410c", border: "#fdba74", icon: "🍳" }, // Orange
  { bg: "linear-gradient(135deg, #f3e8ff, #e9d5ff)", text: "#7e22ce", border: "#d8b4fe", icon: "🔮" }, // Purple
  { bg: "linear-gradient(135deg, #fee2e2, #fecaca)", text: "#b91c1c", border: "#fca5a5", icon: "❤️" }, // Red
  { bg: "linear-gradient(135deg, #e0f2fe, #bae6fd)", text: "#0369a1", border: "#7dd3fc", icon: "📱" }, // Cyan
  { bg: "linear-gradient(135deg, #f1f5f9, #e2e8f0)", text: "#334155", border: "#cbd5e1", icon: "📝" }, // Slate
];

// Helper to get color theme for category index
function getCategoryTheme(index) {
  return categoryColors[index % categoryColors.length];
}
---

<Layout title={`${siteConfig.title} - ${siteConfig.slogan}`} description={siteConfig.description} preloadImage={heroPost?.data?.heroImage} showSidebar={false}>
  
  {isFirstPage ? (
    <!-- 1. HERO SECTION WITH SEARCH AND FEATURED POST SIDE-BY-SIDE -->
    <section class="portal-hero">
      <div class="portal-hero-container">
        <!-- Left: Branding & Search -->
        <div class="hero-branding">
          <div class="hero-badges">
            <span class="hero-badge badge-premium">⭐ 100% Honestos</span>
            <span class="hero-badge badge-review">✓ Testados</span>
          </div>
          <h1 class="portal-title">{siteConfig.title} <span class="accent-dot">.</span></h1>
          <p class="portal-subtitle">{siteConfig.focus || siteConfig.description}</p>
          
          <!-- Search box -->
          <div class="search-box">
            <div class="search-input-wrapper">
              <span class="search-icon">🔍</span>
              <input type="text" id="portal-search-input" placeholder="O que você está procurando?" />
            </div>
            <button class="search-btn" id="portal-search-btn">Buscar</button>
          </div>
        </div>
        
        <!-- Right: Premium Featured Post Card -->
        <div class="hero-featured">
          {heroPost && (
            <div class="featured-card">
              <span class="featured-badge">DESTAQUE</span>
              {heroPost.data.heroImage && (
                <div class="featured-img-wrapper">
                  <a href={`/${heroPost.slug}`}>
                    <img src={heroPost.data.heroImage} alt={heroPost.data.title} width="600" height="340" fetchpriority="high" loading="eager" />
                  </a>
                </div>
              )}
              <div class="featured-content">
                <span class="featured-category">{heroPost.data.category || 'Destaque'}</span>
                <h2 class="featured-title">
                  <a href={`/${heroPost.slug}`}>{heroPost.data.title}</a>
                </h2>
                <a href={`/${heroPost.slug}`} class="featured-link">Ler artigo completo &rarr;</a>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- 2. RED ACCENT CHECKLIST BAR -->
    <section class="checklist-bar">
      <div class="checklist-container">
        <div class="checklist-item">
          <span class="check-icon">✓</span>
          <span>Avaliações 100% Isentas</span>
        </div>
        <div class="checklist-item">
          <span class="check-icon">✓</span>
          <span>Sem Patrocínio Pago</span>
        </div>
        <div class="checklist-item">
          <span class="check-icon">✓</span>
          <span>Análises Minuciosas</span>
        </div>
        <div class="checklist-item">
          <span class="check-icon">✓</span>
          <span>Aprovado por Editores</span>
        </div>
      </div>
    </section>

    <!-- 3. CATEGORIES GRID SECTION -->
    <section class="categories-section">
      <div class="section-container">
        <h2 class="block-title">Explorar Categorias</h2>
        <div class="categories-grid">
          {displayCategories.map((cat, index) => {
            const theme = getCategoryTheme(index);
            const count = allPosts.filter(p => p.data.category === cat).length || 5;
            return (
              <a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="category-card" style={`background: ${theme.bg}; border: 1px solid ${theme.border};`}>
                <div class="category-icon-box" style={`color: ${theme.text};`}>
                  <span class="cat-icon">{theme.icon}</span>
                </div>
                <div class="category-info">
                  <h3 style={`color: ${theme.text};`}>{cat}</h3>
                  <p>{count} artigos</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- 4. RECENT ARTICLES SECTION (3-COLUMN MINI GRID) -->
    <section class="recent-section">
      <div class="section-container">
        <h2 class="block-title">Artigos Recentes</h2>
        <div class="recent-grid">
          {recentPosts.map(post => (
            <article class="mini-post-card">
              {post.data.heroImage && (
                <div class="mini-img-wrapper">
                  <a href={`/${post.slug}`}>
                    <img src={post.data.heroImage} alt={post.data.title} loading="lazy" width="120" height="80" />
                  </a>
                </div>
              )}
              <div class="mini-content">
                <span class="mini-category">{post.data.category || 'Geral'}</span>
                <h3 class="mini-title">
                  <a href={`/${post.slug}`}>{post.data.title}</a>
                </h3>
                <span class="mini-date">
                  📅 {new Date(post.data.pubDate).toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric'
                  })}
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. TWO COLUMN GRID BY CATEGORY -->
    <section class="category-blocks-section">
      <div class="section-container">
        <div class="category-blocks-grid">
          {displayCategories.slice(0, 8).map((cat, index) => {
            const catPosts = sortedAllPosts.filter(p => p.data.category === cat).slice(0, 4);
            if (catPosts.length === 0) return null;
            return (
              <div class="category-block card">
                <div class="block-header">
                  <h3>{cat}</h3>
                  <a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="block-see-all">ver tudo &rarr;</a>
                </div>
                <div class="block-posts-list">
                  {catPosts.map(post => (
                    <div class="block-list-item">
                      {post.data.heroImage && (
                        <div class="list-item-img">
                          <img src={post.data.heroImage} alt={post.data.title} width="60" height="60" loading="lazy" />
                        </div>
                      )}
                      <div class="list-item-info">
                        <h4>
                          <a href={`/${post.slug}`}>{post.data.title}</a>
                        </h4>
                        <span class="list-item-date">
                          📅 {new Date(post.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })}
                        </span>
                      </div>
                      <a href={`/${post.slug}`} class="list-item-arrow">&rarr;</a>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- 6. PREMIUM RECOMMENDATION NEWSLETTER BANNER -->
    <section class="newsletter-banner">
      <div class="newsletter-container">
        <div class="newsletter-branding">
          <h2>Receba nossas recomendações</h2>
          <p>As melhores análises direto na sua caixa de entrada toda semana.</p>
        </div>
        <div class="newsletter-form">
          <input type="email" placeholder="Seu melhor e-mail" required />
          <button type="button">Inscrever-se</button>
        </div>
      </div>
    </section>

  ) : (
    <!-- PAGINATED ARTICLES VIEW FOR PAGE 2+ -->
    <section class="paginated-view">
      <div class="section-container" style="padding-top: 4rem; padding-bottom: 4rem;">
        <h1 class="block-title" style="margin-bottom: 2rem;">Análises Publicadas - Página {page.currentPage}</h1>
        <div class="paginated-grid">
          {page.data.map(post => (
            <article class="standard-post-card card">
              {post.data.heroImage && (
                <div class="standard-img-box">
                  <a href={`/${post.slug}`}>
                    <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                  </a>
                </div>
              )}
              <div class="standard-content">
                <span class="standard-category">{post.data.category}</span>
                <h2><a href={`/${post.slug}`}>{post.data.title}</a></h2>
                <p>{post.data.description}</p>
                <span class="standard-date">📅 {new Date(post.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
              </div>
            </article>
          ))}
        </div>

        <!-- Pagination Controls -->
        {(page.url.prev || page.url.next) && (
          <nav class="pagination-nav">
            {page.url.prev ? <a href={page.url.prev} class="pagination-btn">&larr; Anterior</a> : <span class="pagination-btn disabled">&larr; Anterior</span>}
            <span class="pagination-indicator">Página <strong>{page.currentPage}</strong> de <strong>{page.lastPage}</strong></span>
            {page.url.next ? <a href={page.url.next} class="pagination-btn">Próximo &rarr;</a> : <span class="pagination-btn disabled">Próximo &rarr;</span>}
          </nav>
        )}
      </div>
    </section>
  )}

</Layout>

<style>
  /* 1. PORTAL HERO STYLE */
  .portal-hero {
    background: radial-gradient(circle at 100% 100%, #171630 0%, #0d0f1a 100%);
    color: #ffffff;
    padding: 4rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .portal-hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .portal-hero-container {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .hero-branding {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-badges {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .hero-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 50px;
    text-transform: uppercase;
  }

  .badge-premium {
    background-color: rgba(225, 29, 72, 0.2);
    color: #fda4af;
    border: 1px solid rgba(225, 29, 72, 0.4);
  }

  .badge-review {
    background-color: rgba(14, 165, 233, 0.2);
    color: #bae6fd;
    border: 1px solid rgba(14, 165, 233, 0.4);
  }

  .portal-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .portal-title {
      font-size: 3.5rem;
    }
  }

  .accent-dot {
    color: #e11d48;
  }

  .portal-subtitle {
    font-size: 1.1rem;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 500px;
  }

  /* Search box */
  .search-box {
    display: flex;
    background-color: #ffffff;
    border-radius: 8px;
    padding: 4px;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    padding-left: 1rem;
    flex: 1;
  }

  .search-icon {
    font-size: 1.1rem;
    color: #94a3b8;
    margin-right: 0.5rem;
  }

  .search-box input {
    border: none;
    outline: none;
    font-size: 1rem;
    color: #0f172a;
    width: 100%;
    background: transparent;
  }

  .search-btn {
    background-color: #e11d48;
    color: #ffffff;
    border: none;
    padding: 0.75rem 1.5rem;
    font-weight: 700;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .search-btn:hover {
    background-color: #be123c;
  }

  /* Right featured card */
  .hero-featured {
    width: 100%;
  }

  .featured-card {
    background-color: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2);
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background-color: #e11d48;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    z-index: 10;
  }

  .featured-img-wrapper {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .featured-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-card:hover .featured-img-wrapper img {
    transform: scale(1.02);
  }

  .featured-content {
    padding: 1.5rem;
  }

  .featured-category {
    font-size: 0.75rem;
    font-weight: 700;
    color: #e11d48;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .featured-title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .featured-title a {
    color: #0f172a;
  }

  .featured-title a:hover {
    color: #e11d48;
    text-decoration: none;
  }

  .featured-link {
    font-weight: 700;
    color: #e11d48;
    font-size: 0.9rem;
  }

  .featured-link:hover {
    color: #be123c;
    text-decoration: underline;
  }

  /* 2. RED ACCENT CHECKLIST BAR */
  .checklist-bar {
    background-color: #e11d48;
    color: #ffffff;
    padding: 1rem;
  }

  .checklist-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    gap: 1rem;
  }

  .checklist-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .check-icon {
    background-color: rgba(255, 255, 255, 0.2);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.75rem;
  }

  /* COMMON SECTION CONTAINER */
  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .block-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 2rem;
    position: relative;
    padding-left: 1rem;
  }

  .block-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background-color: #e11d48;
    border-radius: 2px;
  }

  /* 3. CATEGORIES SECTION */
  .categories-section {
    background-color: #f8fafc;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .categories-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .category-card {
    display: flex;
    align-items: center;
    padding: 1.25rem;
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .category-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
  }

  .category-icon-box {
    background-color: #ffffff;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    margin-right: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .cat-icon {
    font-size: 1.25rem;
  }

  .category-info h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.15rem;
  }

  .category-info p {
    font-size: 0.8rem;
    color: #64748b;
  }

  /* 4. RECENT ARTICLES (3-COLUMN MINI GRID) */
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .recent-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mini-post-card {
    display: flex;
    gap: 1rem;
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    padding: 1rem;
    border-radius: 12px;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .mini-post-card:hover {
    transform: translateY(-2px);
    border-color: #cbd5e1;
  }

  .mini-img-wrapper {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .mini-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mini-content {
    display: flex;
    flex-direction: column;
  }

  .mini-category {
    font-size: 0.65rem;
    font-weight: 700;
    color: #e11d48;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .mini-title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.4rem;
  }

  .mini-title a {
    color: #0f172a;
  }

  .mini-title a:hover {
    color: #e11d48;
    text-decoration: none;
  }

  .mini-date {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  /* 5. TWO COLUMN CATEGORY BLOCKS */
  .category-blocks-section {
    background-color: #f1f5f9;
  }

  .category-blocks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .category-blocks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .category-block {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #f1f5f9;
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .block-header h3 {
    font-size: 1.2rem;
    font-weight: 800;
    color: #0f172a;
  }

  .block-see-all {
    font-size: 0.8rem;
    font-weight: 700;
    color: #e11d48;
    text-transform: uppercase;
  }

  .block-posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .block-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f8fafc;
  }

  .block-list-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .list-item-img {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .list-item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .list-item-info {
    flex: 1;
  }

  .list-item-info h4 {
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .list-item-info h4 a {
    color: #1e293b;
  }

  .list-item-info h4 a:hover {
    color: #e11d48;
    text-decoration: none;
  }

  .list-item-date {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .list-item-arrow {
    color: #94a3b8;
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* 6. NEWSLETTER BANNER */
  .newsletter-banner {
    background-color: #0f172a;
    color: #ffffff;
    padding: 3rem 1.5rem;
  }

  .newsletter-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .newsletter-container {
