---
import siteConfig from '../siteConfig.json';
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="footer-logo">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="var(--primary-color)" stroke="var(--primary-color)" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="logo-text">
          <span class="logo-title">{siteConfig.title}</span>
          <span class="logo-subtitle">{siteConfig.subtitle}</span>
        </div>
      </div>
      <p class="brand-desc">{siteConfig.description}</p>
    </div>
    
    <div class="footer-info">
      <div class="info-group">
        <span class="info-title">Nosso Foco:</span>
        <p class="info-content">{siteConfig.focus}</p>
      </div>
      
      <div class="info-group">
        <span class="info-title">Atualizado:</span>
        <p class="info-content">{siteConfig.updated}</p>
      </div>
      
      <div class="info-group">
        <span class="info-title">Aviso de Afiliado:</span>
        <p class="info-content">{siteConfig.affiliateNotice}</p>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="bottom-container">
      <p class="copyright">&copy; {new Date().getFullYear()} {siteConfig.title} - Todos os direitos reservados.</p>
      <div class="bottom-links">
        <a href="/">Home</a>
        <a href="/politica-de-privacidade">Política de Privacidade</a>
        <a href="/contato">Contato</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #ffffff;
    border-top: 1px solid var(--border-color);
    padding: 3rem 0 1.5rem 0;
    margin-top: auto;
    color: var(--text-main);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 2.5rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-container {
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    width: 42px;
    height: 42px;
    background-color: #e0f2fe;
    border: 2px solid #bae6fd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7px;
  }

  .logo-icon svg {
    width: 100%;
    height: 100%;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-title {
    font-weight: 800;
    font-size: 1.15rem;
    color: #0f172a;
    letter-spacing: 0.05em;
    line-height: 1.1;
  }

  .logo-subtitle {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: lowercase;
  }

  .brand-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 400px;
    line-height: 1.5;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .info-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0f172a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .info-content {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .info-content a {
    color: var(--text-muted);
  }

  .info-content a:hover {
    color: var(--primary-color);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
  }

  .bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .bottom-container {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .copyright {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .bottom-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .bottom-links a:hover {
    color: var(--primary-color);
  }
</style>
