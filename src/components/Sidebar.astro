---
import { getCollection } from 'astro:content';
import siteConfig from '../siteConfig.json';

let posts = [];
try {
  posts = await getCollection('blog');
} catch (e) {
  // Caso a coleção ainda não esteja pronta ou vazia
}

const recentPosts = posts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 7);

// Extrair categorias reais dos posts dinamicamente de forma automática!
const uniqueCategories = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
const categories = uniqueCategories.map(cat => ({
  name: cat.charAt(0).toUpperCase() + cat.slice(1),
  slug: cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')
}));

const recommendedProducts = siteConfig.recommendedProducts || [];
---

<div class="sidebar-container">
  <!-- Navegação de Páginas -->
  <section class="sidebar-section pages-nav-section">
    <h3 class="section-title">Navegação</h3>
    <ul class="nav-pages-list">
      <li>
        <a href="/">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Página Inicial</span>
        </a>
      </li>
      <li>
        <a href="/politica-de-privacidade">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Política de Privacidade</span>
        </a>
      </li>
      <li>
        <a href="/contato">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="nav-icon"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>Fale Conosco</span>
        </a>
      </li>
    </ul>
  </section>

  <!-- Posts Recentes -->
  <section class="sidebar-section">
    <h3 class="section-title">Posts Recentes</h3>
    <ul class="recent-posts-list">
      {recentPosts.length > 0 ? (
        recentPosts.map(post => (
          <li>
            <a href={`/${post.slug}`} title={post.data.title}>{post.data.title}</a>
          </li>
        ))
      ) : (
        <li><a href="/">Como Escolher o Melhor Colchão: Guia Completo</a></li>
        <li><a href="/">Os Melhores Colchões de Molas Ensacadas</a></li>
        <li><a href="/">Qual a Densidade Ideal para o Seu Tipo Físico?</a></li>
      )}
    </ul>
  </section>

  <!-- Categorias -->
  <section class="sidebar-section">
    <h3 class="section-title">Categorias</h3>
    <ul class="categories-list">
      {categories.map(cat => (
        <li>
          <a href={`/?category=${cat.slug}`}>{cat.name}</a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Produtos Recomendados -->
  {recommendedProducts.length > 0 && (
    <section class="sidebar-section amazon-products-section">
      <h3 class="section-title">Recomendados</h3>
      <div class="recommended-products">
        {recommendedProducts.map(prod => (
          <div class="prod-card">
            <div class="prod-img">
              <img src={prod.image} alt={prod.title} loading="lazy" width="65" height="65" decoding="async" />
            </div>
            <div class="prod-info">
              <h4 class="prod-title" title={prod.title}>{prod.title}</h4>
              <div class="prod-rating">
                <span class="stars">{"★".repeat(Math.floor(prod.rating)) + (prod.rating % 1 >= 0.5 ? "½" : "")}</span>
                <span class="rating-val">{prod.rating} ({prod.reviews})</span>
              </div>
              <p class="prod-price">{prod.priceRange}</p>
              <a href={prod.link} target="_blank" rel="noopener noreferrer nofollow" class="buy-button">
                Ver preço aqui
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .sidebar-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sidebar-section {
    background-color: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.5rem;
    box-shadow: var(--shadow-subtle);
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--primary-color);
    color: #0f172a;
    display: inline-block;
  }

  /* Menu de Navegação Lateral */
  .pages-nav-section {
    background-color: #ffffff;
  }

  .nav-pages-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-pages-list li {
    padding: 0;
    margin: 0;
  }

  .nav-pages-list a {
    color: #475569;
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease-in-out;
  }

  .nav-pages-list a:hover {
    color: var(--primary-color);
    background-color: var(--bg-color);
    text-decoration: none;
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .nav-pages-list a:hover .nav-icon {
    transform: scale(1.1);
  }

  /* Listas Recentes e Categorias */
  .recent-posts-list, .categories-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .recent-posts-list a {
    color: #334155;
    font-size: 0.95rem;
    line-height: 1.4;
    display: block;
  }

  .recent-posts-list a:hover {
    color: var(--primary-color);
  }

  .recent-posts-list li {
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 0.75rem;
  }

  .recent-posts-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .categories-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .categories-list a {
    color: #475569;
    font-size: 0.85rem;
    background-color: #f0f9ff;
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    padding: 0.5rem;
    text-align: center;
    display: block;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .categories-list a:hover {
    background-color: #e0f2fe;
    border-color: #bae6fd;
    color: var(--primary-color);
    text-decoration: none;
  }

  /* Produtos Recomendados */
  .recommended-products {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .prod-card {
    display: flex;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .prod-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .prod-img {
    width: 65px;
    height: 65px;
    flex-shrink: 0;
  }

  .prod-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid var(--border-color);
  }

  .prod-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .prod-title {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.3;
    color: #1e293b;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prod-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
  }

  .stars {
    color: #eab308;
    font-weight: bold;
  }

  .rating-val {
    color: var(--text-muted);
  }

  .prod-price {
    font-size: 0.8rem;
    font-weight: 700;
    color: #0f172a;
  }

  .buy-button {
    font-size: 0.75rem;
    background-color: var(--primary-color);
    color: #ffffff !important;
    font-weight: 700;
    padding: 0.35rem 0.75rem;
    border-radius: 0.25rem;
    text-align: center;
    display: inline-block;
    transition: background-color 0.2s ease;
  }

  .buy-button:hover {
    background-color: var(--primary-hover);
    text-decoration: none;
  }
</style>

